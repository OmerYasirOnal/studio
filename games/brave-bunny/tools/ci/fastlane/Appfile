# Apple developer team ids and ASC team ids are NOT secrets per Apple's docs
# (they appear in your provisioning profiles already) but we still allow env
# overrides so this file stays portable across forks / re-keying events.

app_identifier "com.omeryasir.bravebunny"   # Brave Bunny iOS bundle id (GAME.md)
team_id ENV["FASTLANE_TEAM_ID"] || "9X8FDSW5D8"  # Yasir's Apple Distribution team

# itc_team_id: only required when an Apple ID belongs to multiple teams. The
# ASC API key (Phase 5) supersedes this. Left as env for safety on shared CI.
itc_team_id ENV["FASTLANE_ITC_TEAM_ID"]

# Apple ID for legacy 2FA path (upload_to_testflight w/o API key).
# Preferred: ASC API key via app_store_connect_api_key action — see Fastfile.
apple_id ENV["FASTLANE_USER"] || "omeryasironal@hotmail.com"

