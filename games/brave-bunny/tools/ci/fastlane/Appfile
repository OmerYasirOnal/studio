# fastlane Appfile — public-facing identifiers only. Secrets via GitHub Actions env.
#
# Owner: build-engineer. Cross-ref: tech-spec 10-build-and-ci.md, GAME.md.
# Bundle id pattern is locked in GAME.md (`bundle_id_pattern`).
#
# Apple developer team ids and ASC team ids are NOT secrets per Apple's docs
# (they appear in your provisioning profiles already) but we still source them
# from env vars so this file stays portable across forks / re-keying events.

app_identifier "com.yasironal.brave-bunny"  # Brave Bunny iOS bundle id (GAME.md)
team_id ENV["FASTLANE_TEAM_ID"]             # Apple Developer team id
itc_team_id ENV["FASTLANE_ITC_TEAM_ID"]     # App Store Connect team id

# Apple ID (account email) for upload_to_testflight / upload_to_app_store.
# App-specific password lives in FASTLANE_APP_SPECIFIC_PASSWORD (env), never here.
apple_id ENV["FASTLANE_USER"]

