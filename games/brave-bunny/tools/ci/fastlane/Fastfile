# Fastfile — Brave Bunny iOS build lanes.
#
# Owner: build-engineer. Cross-ref: tech-spec 10-build-and-ci.md ("Fastlane lanes").
# Three lanes — preview (local archive), beta (TestFlight), release (App Store).
#
# Lane invocation:
#   bundle exec fastlane ios preview   # local-only archive, no upload
#   bundle exec fastlane ios beta      # CI TestFlight upload
#   bundle exec fastlane ios release   # MANUAL gate — App Store submission
#
# Environment variables expected (see runbooks/first-build.md):
#   MATCH_PASSWORD                — decrypt cert repo (studio-certs)
#   MATCH_GIT_AUTHOR              — GitHub user for cert repo access
#   FASTLANE_USER                 — Apple ID email
#   FASTLANE_PASSWORD             — Apple ID password (avoid; prefer app-specific)
#   FASTLANE_APP_SPECIFIC_PASSWORD — preferred over FASTLANE_PASSWORD
#   FASTLANE_TEAM_ID              — Apple Developer team id
#   FASTLANE_ITC_TEAM_ID          — App Store Connect team id
#
# Paths in this file are RELATIVE TO THIS FILE (fastlane sets CWD to its own dir).
# games/brave-bunny/tools/ci/fastlane/Fastfile
#   ../../../unity/Build/iOS = games/brave-bunny/unity/Build/iOS

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

UNITY_PROJECT_PATH     = File.expand_path("../../../unity", __dir__)
IOS_BUILD_DIR          = File.join(UNITY_PROJECT_PATH, "Build", "iOS")
IOS_XCODEPROJ          = File.join(IOS_BUILD_DIR, "Unity-iPhone.xcodeproj")
IOS_XCWORKSPACE        = File.join(IOS_BUILD_DIR, "Unity-iPhone.xcworkspace")
BUILD_OUTPUT_ROOT      = File.expand_path("../../../Builds", __dir__)
APP_IDENTIFIER         = "com.omeryasir.bravebunny"
APP_NAME               = "Brave Bunny"
APP_PRIMARY_LANGUAGE   = "en-US"
APP_SKU                = "bravebunny"
UNITY_BUILD_SCRIPT     = File.expand_path("../scripts/unity-build-ios.sh", __dir__)

# App Store Connect API key paths. The .p8 file lives outside the repo
# (~/.appstoreconnect/private_keys/) so it never leaks; key_id + issuer_id
# can be public (they're identifiers, not credentials).
ASC_KEY_ID    = "93HFBMV3MA"
ASC_ISSUER_ID = "3894e346-c886-4ca5-91b7-773aaa6e85bd"
ASC_KEY_PATH  = File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{ASC_KEY_ID}.p8")

# ---------------------------------------------------------------------------
# Global hooks
# ---------------------------------------------------------------------------

default_platform(:ios)

before_all do |lane, options|
  # Lock Xcode version — IL2CPP + Unity 6 LTS targets Xcode 16+ (see tech-spec 00).
  # Comment out if running with a pinned non-default Xcode locally.
  ensure_xcode_version(version: "16.0") if ENV["CI"]

  # fastlane's CI helper: configures keychain, disables prompts, sets timeouts.
  setup_ci if ENV["CI"]

  UI.message("[fastlane] lane=#{lane} ci=#{ENV['CI'].to_s.empty? ? 'no' : 'yes'}")
  UI.message("[fastlane] unity project: #{UNITY_PROJECT_PATH}")
end

after_all do |lane|
  UI.success("[fastlane] lane=#{lane} completed")
end

error do |lane, exception|
  UI.error("[fastlane] lane=#{lane} FAILED: #{exception.message}")
  # No Slack / Discord webhook here — tech-spec 10 disallows paid services and
  # we have not yet provisioned a free webhook. Re-add when observer dashboard
  # has a notification surface.
end

# ---------------------------------------------------------------------------
# Private helpers
# ---------------------------------------------------------------------------

# Invoke headless Unity build via the dedicated shell script.
# Keeping this as a sh-out (not Ruby) means local devs can run the same script
# without a fastlane install.
private_lane :unity_build do |options|
  target = options[:target] || "iOS"
  UI.user_error!("unity_build: only iOS target wired in v0.1 (got #{target})") unless target == "iOS"
  UI.message("[unity_build] invoking #{UNITY_BUILD_SCRIPT}")
  sh("bash", UNITY_BUILD_SCRIPT)
  UI.user_error!("unity_build: expected #{IOS_XCODEPROJ}") unless File.exist?(IOS_XCODEPROJ)
end

# Validate required env vars early — fails fast with a readable message.
private_lane :require_env do |options|
  missing = (options[:vars] || []).reject { |v| ENV[v] && !ENV[v].empty? }
  unless missing.empty?
    UI.user_error!("Missing required env vars: #{missing.join(', ')}. See runbooks/first-build.md.")
  end
end

# Authenticate against App Store Connect via API key (.p8). Required for
# every lane that talks to ASC. Returns the api_key hash that other actions
# consume via `api_key:` parameter.
private_lane :asc_api_key do
  unless File.exist?(ASC_KEY_PATH)
    UI.user_error!("[asc] API key not found at #{ASC_KEY_PATH}. " \
                   "Download from https://appstoreconnect.apple.com/access/users and place there.")
  end
  app_store_connect_api_key(
    key_id: ASC_KEY_ID,
    issuer_id: ASC_ISSUER_ID,
    key_filepath: ASC_KEY_PATH,
    duration: 1200,            # 20-minute token
    in_house: false
  )
end

# ---------------------------------------------------------------------------
# Platform: iOS
# ---------------------------------------------------------------------------

platform :ios do

  # -------------------------------------------------------------------------
  # Lane: register_app
  # Idempotent — creates the Apple Developer bundle ID + ASC app entry if
  # they don't already exist. Run ONCE per game when starting a new project.
  # Replaces the manual "create app in ASC web UI" runbook step.
  # -------------------------------------------------------------------------
  desc "Create Apple Developer bundle ID + App Store Connect app entry (idempotent)"
  lane :register_app do
    api_key = asc_api_key

    require 'spaceship'
    token = Spaceship::ConnectAPI::Token.create(
      key_id: api_key[:key_id],
      issuer_id: api_key[:issuer_id],
      key: api_key[:key]
    )
    Spaceship::ConnectAPI.token = token

    # 1. Bundle ID on Apple Developer Portal
    existing_bid = Spaceship::ConnectAPI::BundleId.all.find { |b| b.identifier == APP_IDENTIFIER }
    if existing_bid
      UI.success("[register] bundle id already exists: #{APP_IDENTIFIER} (id=#{existing_bid.id})")
    else
      UI.message("[register] creating bundle id #{APP_IDENTIFIER}...")
      Spaceship::ConnectAPI::BundleId.create(
        name: APP_NAME,
        identifier: APP_IDENTIFIER,
        platform: "IOS",
        seed_id: nil
      )
      UI.success("[register] bundle id created: #{APP_IDENTIFIER}")
    end

    # 2. App Store Connect entry — use `produce` action which has a more lenient
    # auth surface for app creation. Requires App Manager role on the API key;
    # if the role is Developer, this fails and the user must create the app
    # in the ASC web UI (one click at https://appstoreconnect.apple.com/apps).
    existing_app = Spaceship::ConnectAPI::App.all.find { |a| a.bundle_id == APP_IDENTIFIER }
    if existing_app
      UI.success("[register] ASC app already exists: #{APP_IDENTIFIER} -> '#{existing_app.name}' (id=#{existing_app.id})")
    else
      UI.message("[register] creating ASC app entry '#{APP_NAME}' via produce...")
      begin
        produce(
          username: ENV["FASTLANE_USER"] || "omeryasironal@hotmail.com",
          app_identifier: APP_IDENTIFIER,
          app_name: APP_NAME,
          language: APP_PRIMARY_LANGUAGE,
          app_version: "0.1.0",
          sku: APP_SKU,
          skip_itc: false,
          skip_devcenter: true,         # already created above
          platform: "ios",
          api_key: api_key
        )
        UI.success("[register] ASC app created via produce")
      rescue => e
        UI.error("[register] ASC app create failed: #{e.message}")
        UI.important("[register] MANUAL FALLBACK: create the app at https://appstoreconnect.apple.com/apps")
        UI.important("  - Platform: iOS")
        UI.important("  - Name: #{APP_NAME}")
        UI.important("  - Primary Language: English (U.S.)")
        UI.important("  - Bundle ID: #{APP_IDENTIFIER}")
        UI.important("  - SKU: #{APP_SKU}")
        UI.important("  - User Access: Full Access (or your preference)")
        UI.important("[register] Cause: API key likely has 'Developer' role; needs 'App Manager' for ASC create.")
        UI.important("  Upgrade at: https://appstoreconnect.apple.com/access/api")
      end
    end

    UI.success("[register] done — bundle id present, ASC entry may need manual creation if create failed")
  end

  # -------------------------------------------------------------------------
  # Lane: enable_iap
  # Adds the In-App Purchase capability to the bundle id. Unity IAP requires it
  # in the Xcode project's entitlements; without IAP enabled at the dev portal
  # the archive step fails with "requires provisioning profile with the
  # In-App Purchase feature".  After this lane, run :refresh_profile.
  # -------------------------------------------------------------------------
  desc "Enable IAP capability on the bundle id (idempotent)"
  lane :enable_iap do
    api_key = asc_api_key
    require 'spaceship'
    token = Spaceship::ConnectAPI::Token.create(
      key_id: api_key[:key_id], issuer_id: api_key[:issuer_id], key: api_key[:key])
    Spaceship::ConnectAPI.token = token

    bid = Spaceship::ConnectAPI::BundleId.all.find { |b| b.identifier == APP_IDENTIFIER }
    UI.user_error!("bundle id #{APP_IDENTIFIER} not found — run register_app first") unless bid

    existing = bid.bundle_id_capabilities || []
    types = existing.map { |c| c.capability_type.to_s }
    UI.message("[enable_iap] existing capabilities: #{types.join(', ')}")
    if types.any? { |t| t.include?("IN_APP_PURCHASE") }
      UI.success("[enable_iap] already enabled")
    else
      bid.create_capability(Spaceship::ConnectAPI::BundleIdCapability::Type::IN_APP_PURCHASE)
      UI.success("[enable_iap] enabled IN_APP_PURCHASE on #{APP_IDENTIFIER}")
    end
  end

  # -------------------------------------------------------------------------
  # Lane: refresh_profile — force re-issue the appstore profile (capability change).
  # -------------------------------------------------------------------------
  desc "Force-refresh the appstore provisioning profile"
  lane :refresh_profile do
    api_key = asc_api_key
    match(
      type: "appstore",
      app_identifier: APP_IDENTIFIER,
      api_key: api_key,
      force: true,
      readonly: false
    )
  end

  # -------------------------------------------------------------------------
  # Lane: list_apps
  # Read-only — list all apps + bundle IDs on this Apple Developer account.
  # Useful for debugging "what's already registered?" without web UI.
  # -------------------------------------------------------------------------
  desc "List all apps and bundle IDs on the Apple Developer account (read-only)"
  lane :list_apps do
    api_key = asc_api_key

    require 'spaceship'
    token = Spaceship::ConnectAPI::Token.create(
      key_id: api_key[:key_id],
      issuer_id: api_key[:issuer_id],
      key: api_key[:key]
    )
    Spaceship::ConnectAPI.token = token

    apps = Spaceship::ConnectAPI::App.all
    UI.message("=== #{apps.count} apps on App Store Connect ===")
    apps.each { |app| UI.message("  #{app.bundle_id.to_s.ljust(40)}  #{app.name}") }

    bids = Spaceship::ConnectAPI::BundleId.all
    UI.message("\n=== #{bids.count} bundle IDs on Apple Developer Portal ===")
    bids.each { |b| UI.message("  #{b.identifier.to_s.ljust(40)}  #{b.name}") }
  end

  # -------------------------------------------------------------------------
  # Lane: preview
  # Local archive without uploading. Useful for smoke-testing the pipeline
  # before any TestFlight push. Safe to run locally.
  # -------------------------------------------------------------------------
  desc "Local archive without uploading (smoke test the pipeline)"
  lane :preview do
    require_env(vars: ["MATCH_PASSWORD"])
    api_key = asc_api_key

    unity_build(target: "iOS")

    match(
      type: "appstore",
      readonly: true,                 # never mutates the cert repo
      app_identifier: APP_IDENTIFIER,
      api_key: api_key
    )

    # Switch the Unity-generated Xcode project from Automatic to Manual signing
    # and pin the exact provisioning profile match installed. Without this,
    # xcodebuild's signing auto-selection occasionally picks a stale profile.
    update_code_signing_settings(
      path: IOS_XCODEPROJ,
      use_automatic_signing: false,
      team_id: "9X8FDSW5D8",
      bundle_identifier: APP_IDENTIFIER,
      code_sign_identity: "Apple Distribution",
      profile_name: "match AppStore #{APP_IDENTIFIER}",
      profile_uuid: ENV["sigh_#{APP_IDENTIFIER}_appstore"],
      targets: ["Unity-iPhone"]
    )

    # Bump CFBundleVersion monotonically — CI run number on CI, timestamp locally.
    build_number = ENV["GITHUB_RUN_NUMBER"] || Time.now.strftime("%Y%m%d%H%M")
    increment_build_number_in_xcodeproj(
      xcodeproj: IOS_XCODEPROJ,
      build_number: build_number
    )

    build_app(
      project: IOS_XCODEPROJ,
      scheme: "Unity-iPhone",
      configuration: "Release",
      export_method: "app-store",
      include_bitcode: false,         # Apple deprecated bitcode in Xcode 14
      output_directory: BUILD_OUTPUT_ROOT,
      output_name: "BraveBunny-preview-#{build_number}.ipa",
      clean: true
    )

    UI.success("[preview] archive: #{lane_context[SharedValues::IPA_OUTPUT_PATH]}")
  end

  # -------------------------------------------------------------------------
  # Lane: beta
  # TestFlight upload. Triggered by GitHub Actions (workflow_dispatch).
  # Requires full Apple credentials in env.
  # -------------------------------------------------------------------------
  desc "Build and upload to TestFlight"
  lane :beta do
    require_env(vars: ["MATCH_PASSWORD"])
    api_key = asc_api_key             # supersedes FASTLANE_USER + 2FA

    unity_build(target: "iOS")

    match(
      type: "appstore",
      readonly: !ENV["CI"].nil?,      # CI: read-only; local: allow refresh
      app_identifier: APP_IDENTIFIER,
      api_key: api_key
    )

    build_number = ENV["GITHUB_RUN_NUMBER"] || Time.now.strftime("%Y%m%d%H%M")
    increment_build_number_in_xcodeproj(
      xcodeproj: IOS_XCODEPROJ,
      build_number: build_number
    )

    build_app(
      project: IOS_XCODEPROJ,
      scheme: "Unity-iPhone",
      configuration: "Release",
      export_method: "app-store",
      include_bitcode: false,
      output_directory: BUILD_OUTPUT_ROOT,
      output_name: "BraveBunny-beta-#{build_number}.ipa",
      clean: true
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      skip_waiting_for_build_processing: true,
      changelog: "See games/brave-bunny/CHANGELOG.md for this build's notes.",
      distribute_external: false,     # internal testers only until v0.2
      reject_build_waiting_for_review: false
    )

    UI.success("[beta] TestFlight upload submitted (build ##{build_number})")
  end

  # -------------------------------------------------------------------------
  # Lane: release
  # App Store submission. MANUAL gate — never auto-runs on CI.
  # This lane uploads the binary but DOES NOT submit for review automatically;
  # the developer reviews metadata in App Store Connect then clicks submit.
  # -------------------------------------------------------------------------
  desc "App Store submission (manual gate — binary upload only, no auto-submit)"
  lane :release do
    if ENV["CI"]
      UI.user_error!("[release] this lane is a MANUAL gate; refusing to run on CI. " \
                     "Trigger it locally after staging review per runbooks/first-build.md.")
    end

    require_env(vars: ["MATCH_PASSWORD"])
    api_key = asc_api_key

    unity_build(target: "iOS")

    match(
      type: "appstore",
      readonly: true,
      app_identifier: APP_IDENTIFIER,
      api_key: api_key
    )

    build_number = Time.now.strftime("%Y%m%d%H%M")
    increment_build_number_in_xcodeproj(
      xcodeproj: IOS_XCODEPROJ,
      build_number: build_number
    )

    build_app(
      project: IOS_XCODEPROJ,
      scheme: "Unity-iPhone",
      configuration: "Release",
      export_method: "app-store",
      include_bitcode: false,
      output_directory: BUILD_OUTPUT_ROOT,
      output_name: "BraveBunny-release-#{build_number}.ipa",
      clean: true
    )

    upload_to_app_store(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      submit_for_review: false,       # manual approval per tech-spec 10
      automatic_release: false,       # manual release after Apple approves
      skip_metadata: true,            # metadata managed in ASC web UI, not git
      skip_screenshots: true,
      precheck_include_in_app_purchases: false
    )

    UI.success("[release] binary uploaded — open App Store Connect to submit for review")
  end

end
