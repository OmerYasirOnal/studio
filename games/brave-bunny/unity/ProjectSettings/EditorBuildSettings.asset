%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
# ----------------------------------------------------------------------------
# EditorBuildSettings — scene list for Brave Bunny.
#
# Stub asset. Unity will rewrite + expand this file on first project open and
# populate the scene GUIDs with real values once the scene files are saved.
# The four shipping scenes are listed per tech-spec 01-project-layout.md:
#   - Boot, MainMenu, Loadout, Run
# Plus the sandbox Test scene (gameplay-engineer + qa-engineer only, NEVER
# built into shipping IPA — its 'enabled' flag is 0 for that reason).
#
# Each scene's `guid` is a placeholder (32 zeros). Unity regenerates the real
# GUIDs when the .unity files are created in-editor; the .meta files will
# carry the canonical GUIDs and this asset will be updated automatically.
# ----------------------------------------------------------------------------
--- !u!1045 &1
EditorBuildSettings:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Scenes:
  - enabled: 1
    path: Assets/_Brave/Scenes/Boot.unity
    guid: 00000000000000000000000000000000
  - enabled: 1
    path: Assets/_Brave/Scenes/MainMenu.unity
    guid: 00000000000000000000000000000000
  - enabled: 1
    path: Assets/_Brave/Scenes/Loadout.unity
    guid: 00000000000000000000000000000000
  - enabled: 1
    path: Assets/_Brave/Scenes/Run.unity
    guid: 00000000000000000000000000000000
  - enabled: 0
    path: Assets/_Brave/Scenes/Test.unity
    guid: 00000000000000000000000000000000
  m_configObjects: {}
