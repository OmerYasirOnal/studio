# OS
.DS_Store
Thumbs.db

# Claude Code worktrees + agent transcripts
.claude/worktrees/
.claude/tasks/

# Editors
.idea/
.vscode/
*.swp
*.swo

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Node
node_modules/
npm-debug.log*
yarn-debug.log*

# Unity (per-game .gitignore inside games/<name>/unity/ handles project-specific items)
**/Library/
**/Temp/
**/Obj/
**/Build/
**/Builds/
**/Logs/
**/UserSettings/
**/MemoryCaptures/

# Studio runtime artifacts
logs/*.jsonl
logs/*.log
games/*/logs/**/*.log
games/*/logs/**/*.jsonl
.active-game.lock

# Secrets — none should exist, this is a paranoia rail
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.p8

# Fastlane runtime artifacts
**/fastlane/report.xml
**/fastlane/test_output/
**/fastlane/Preview.html
**/fastlane/screenshots/**/*.png
**/fastlane/test_output/**

# Unity license artifacts (machine-bound, not for sharing)
Unity_v*.alf
Unity_v*.ulf
Unity_lic.ulf

# iOS build artifacts (regenerable via fastlane preview / beta)
games/*/Builds/*.ipa
games/*/Builds/*.dSYM.zip
games/*/Builds/*.xcarchive
games/*/unity/Build/iOS/

# Generated Unity project files
games/*/unity/Library/
games/*/unity/Temp/
games/*/unity/Obj/
games/*/unity/Logs/
games/*/unity/MemoryCaptures/
games/*/unity/UserSettings/

# Assets we never commit raw
games/*/assets-raw/**/*.psd
games/*/assets-raw/**/*.blend1

# Marketing screenshot pipeline outputs — capture-screenshots.sh writes PNGs
# here; we keep the JSON spec + copy in git but the rendered PNGs are
# regenerable artifacts (build-engineer runs the script before each ASC push).
games/*/marketing/screenshots/**/*.png
games/*/marketing/screenshots/**/*.png.txt

# OS artifacts (macOS Finder icon stub uses a literal carriage-return; '?' glob
# would catch our 'icons/' directories)
Icon[$'\r']
